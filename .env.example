# PlumberConnect Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# Client Configuration
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# M-Pesa Configuration (for production)
# MPESA_CONSUMER_KEY=your_key_here
# MPESA_CONSUMER_SECRET=your_secret_here
# MPESA_SHORTCODE=your_shortcode_here

# Database Configuration (for production)
# DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/plumberconnect

# Email Configuration (for production)
# SENDGRID_API_KEY=your_key_here
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_password

# JWT Configuration (for production)
# JWT_SECRET=your_secret_key_here
# JWT_EXPIRE=7d

# AWS S3 Configuration (for file uploads in production)
# AWS_ACCESS_KEY_ID=your_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_here
# AWS_BUCKET_NAME=plumberconnect-uploads
# AWS_REGION=eu-west-1
